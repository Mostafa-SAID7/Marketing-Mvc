@model newApp.Models.ViewModels.Home.HomeVM

@{
    ViewData["Title"] = "Home";
    ViewBag.PageTitle = "Welcome to newApp";
    ViewBag.Breadcrumbs = new List<(string Name, string Controller, string Action)>
    {
        ("Home", "Home", "Index")
    };
}

@await Html.PartialAsync("_PageHeader")

<div class="container">
    <!-- Statistics Section -->
    <div class="row mb-5">
        <div class="col-md-4 mb-3">
            <div class="stats-card">
                <div class="stats-number">@Model.TotalProducts</div>
                <div class="stats-label">Products</div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="stats-card">
                <div class="stats-number">@Model.TotalOrders</div>
                <div class="stats-label">Orders</div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="stats-card">
                <div class="stats-number">@Model.TotalCustomers</div>
                <div class="stats-label">Customers</div>
            </div>
        </div>
    </div>

    <!-- Featured Products Section -->
    @if (Model.FeaturedProducts.Any())
    {
        <div class="home-section">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="fas fa-star me-2"></i>Featured Products</h2>
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary">
                    View All Products <i class="fas fa-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var product in Model.FeaturedProducts)
                {
                    @await Html.PartialAsync("_ProductCard", product)
                }
            </div>
        </div>
    }

    <!-- On Sale Products Section -->
    @if (Model.OnSaleProducts.Any())
    {
        <div class="home-section">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="fas fa-fire me-2"></i>On Sale</h2>
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-danger">
                    View All Sales <i class="fas fa-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                @foreach (var product in Model.OnSaleProducts)
                {
                    @await Html.PartialAsync("_ProductCard", product)
                }
            </div>
        </div>
    }

    <!-- Latest Products Section -->
    @if (Model.LatestProducts.Any())
    {
        <div class="home-section">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="fas fa-clock me-2"></i>Latest Products</h2>
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-success">
                    View All Products <i class="fas fa-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
                @foreach (var product in Model.LatestProducts)
                {
                    @await Html.PartialAsync("_ProductCard", product)
                }
            </div>
        </div>
    }

    <!-- Quick Actions Section -->
    <div class="home-section">
        <div class="content-card">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h3>Manage Your Store</h3>
                    <p class="text-muted mb-0">Use the management tools to add products, process orders, and manage your inventory.</p>
                </div>
                <div class="col-md-4 text-md-end">
                    <div class="btn-group-vertical btn-group-sm d-md-none mb-3" role="group">
                        <a asp-controller="Products" asp-action="Create" class="btn btn-outline-primary">
                            <i class="fas fa-plus me-1"></i>Add Product
                        </a>
                        <a asp-controller="Orders" asp-action="Index" class="btn btn-outline-success">
                            <i class="fas fa-list me-1"></i>View Orders
                        </a>
                        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-info">
                            <i class="fas fa-box me-1"></i>Manage Products
                        </a>
                    </div>
                    <div class="btn-group d-none d-md-block" role="group">
                        <a asp-controller="Products" asp-action="Create" class="btn btn-outline-primary">
                            <i class="fas fa-plus me-1"></i>Add Product
                        </a>
                        <a asp-controller="Orders" asp-action="Index" class="btn btn-outline-success">
                            <i class="fas fa-list me-1"></i>Orders
                        </a>
                        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-info">
                            <i class="fas fa-box me-1"></i>Products
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function addToCart(productId) {
            // TODO: Implement add to cart functionality
            window.toaster.info('Add to cart functionality will be implemented soon!');
        }
    </script>
}
