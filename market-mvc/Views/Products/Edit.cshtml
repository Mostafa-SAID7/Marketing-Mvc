@model newApp.Models.ViewModels.Product.ProductEditVM

@{
    ViewData["Title"] = "Edit Product";
    ViewBag.PageTitle = "Edit Product";
    ViewBag.Breadcrumbs = new List<(string Name, string Controller, string Action)>
    {
        ("Products", "Products", "Index"),
        ("Edit", "Products", "Edit")
    };
}

@await Html.PartialAsync("_PageHeader")

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <div class="form-enhanced">
                <form asp-action="Edit" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger-enhanced"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <input type="hidden" asp-for="CurrentImageUrl" />
                    
                    <div class="row">
                        <!-- Left Column - Basic Info -->
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Name" class="control-label">
                                    <i class="fas fa-tag me-2"></i>Product Name *
                                </label>
                                <input asp-for="Name" class="form-control" placeholder="Enter product name" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                            
                            <div class="form-group">
                                <label asp-for="Description" class="control-label">
                                    <i class="fas fa-align-left me-2"></i>Description
                                </label>
                                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Enter product description"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>
                            
                            <div class="row">
                                <div class="col-sm-6">
                                    <div class="form-group">
                                        <label asp-for="Price" class="control-label">
                                            <i class="fas fa-dollar-sign me-2"></i>Price *
                                        </label>
                                        <input asp-for="Price" class="form-control" placeholder="0.00" step="0.01" />
                                        <span asp-validation-for="Price" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="form-group">
                                        <label asp-for="CompareAtPrice" class="control-label">
                                            <i class="fas fa-tags me-2"></i>Compare Price
                                        </label>
                                        <input asp-for="CompareAtPrice" class="form-control" placeholder="0.00" step="0.01" />
                                        <span asp-validation-for="CompareAtPrice" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="form-group">
                                <label asp-for="CategoryId" class="control-label">
                                    <i class="fas fa-folder me-2"></i>Category
                                </label>
                                <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-control">
                                    <option value="">Select a category</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                            
                            <div class="form-group">
                                <label asp-for="Status" class="control-label">
                                    <i class="fas fa-toggle-on me-2"></i>Status
                                </label>
                                <select asp-for="Status" asp-items="ViewBag.ProductStatuses" class="form-control"></select>
                                <span asp-validation-for="Status" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <!-- Right Column - Images & Inventory -->
                        <div class="col-md-6">
                            <!-- Current Image Display -->
                            @if (!string.IsNullOrEmpty(Model.CurrentImageUrl))
                            {
                                <div class="form-group">
                                    <label class="control-label">Current Image</label>
                                    <div class="current-image-container">
                                        <img src="@Model.CurrentImageUrl" alt="@Model.ImageAlt" class="img-fluid rounded" style="max-height: 200px; object-fit: cover;" />
                                    </div>
                                </div>
                            }
                            
                            <!-- Image Upload -->
                            <div class="form-group">
                                <label asp-for="ImageFile" class="control-label">
                                    <i class="fas fa-upload me-2"></i>Upload New Image
                                </label>
                                <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                                <span asp-validation-for="ImageFile" class="text-danger"></span>
                                <small class="form-text text-muted">Supported formats: JPG, PNG, GIF, WebP (Max 5MB)</small>
                            </div>
                            
                            <!-- Image URL Alternative -->
                            <div class="form-group">
                                <label asp-for="ImageUrl" class="control-label">
                                    <i class="fas fa-link me-2"></i>Or Image URL
                                </label>
                                <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/image.jpg" />
                                <span asp-validation-for="ImageUrl" class="text-danger"></span>
                                <small class="form-text text-muted">Enter a URL to an image (alternative to upload)</small>
                            </div>
                            
                            <div class="form-group">
                                <label asp-for="ImageAlt" class="control-label">
                                    <i class="fas fa-eye me-2"></i>Image Alt Text
                                </label>
                                <input asp-for="ImageAlt" class="form-control" placeholder="Describe the image for accessibility" />
                                <span asp-validation-for="ImageAlt" class="text-danger"></span>
                            </div>
                            
                            <!-- Inventory -->
                            <div class="row">
                                <div class="col-sm-6">
                                    <div class="form-group">
                                        <label asp-for="StockQuantity" class="control-label">
                                            <i class="fas fa-boxes me-2"></i>Stock Quantity
                                        </label>
                                        <input asp-for="StockQuantity" class="form-control" />
                                        <span asp-validation-for="StockQuantity" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="form-group">
                                        <label asp-for="LowStockThreshold" class="control-label">
                                            <i class="fas fa-exclamation-triangle me-2"></i>Low Stock Alert
                                        </label>
                                        <input asp-for="LowStockThreshold" class="form-control" />
                                        <span asp-validation-for="LowStockThreshold" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="form-group">
                                <div class="form-check">
                                    <input asp-for="TrackQuantity" class="form-check-input" />
                                    <label asp-for="TrackQuantity" class="form-check-label">
                                        Track inventory quantity
                                    </label>
                                </div>
                            </div>
                            
                            <div class="form-group">
                                <div class="form-check">
                                    <input asp-for="IsFeatured" class="form-check-input" />
                                    <label asp-for="IsFeatured" class="form-check-label">
                                        Featured product
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Advanced Fields (Collapsible) -->
                    <div class="mt-4">
                        <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="collapse" data-bs-target="#advancedFields">
                            <i class="fas fa-cog me-2"></i>Advanced Options
                        </button>
                        
                        <div class="collapse mt-3" id="advancedFields">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="Sku" class="control-label">
                                            <i class="fas fa-barcode me-2"></i>SKU
                                        </label>
                                        <input asp-for="Sku" class="form-control" placeholder="Product SKU" />
                                        <span asp-validation-for="Sku" class="text-danger"></span>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label asp-for="Barcode" class="control-label">
                                            <i class="fas fa-qrcode me-2"></i>Barcode
                                        </label>
                                        <input asp-for="Barcode" class="form-control" placeholder="Product barcode" />
                                        <span asp-validation-for="Barcode" class="text-danger"></span>
                                    </div>
                                    
                                    <div class="row">
                                        <div class="col-sm-8">
                                            <div class="form-group">
                                                <label asp-for="Weight" class="control-label">
                                                    <i class="fas fa-weight me-2"></i>Weight
                                                </label>
                                                <input asp-for="Weight" class="form-control" step="0.01" />
                                                <span asp-validation-for="Weight" class="text-danger"></span>
                                            </div>
                                        </div>
                                        <div class="col-sm-4">
                                            <div class="form-group">
                                                <label asp-for="WeightUnit" class="control-label">Unit</label>
                                                <select asp-for="WeightUnit" class="form-control">
                                                    <option value="kg">kg</option>
                                                    <option value="g">g</option>
                                                    <option value="lb">lb</option>
                                                    <option value="oz">oz</option>
                                                </select>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="CostPrice" class="control-label">
                                            <i class="fas fa-calculator me-2"></i>Cost Price
                                        </label>
                                        <input asp-for="CostPrice" class="form-control" placeholder="0.00" step="0.01" />
                                        <span asp-validation-for="CostPrice" class="text-danger"></span>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label asp-for="SortOrder" class="control-label">
                                            <i class="fas fa-sort me-2"></i>Sort Order
                                        </label>
                                        <input asp-for="SortOrder" class="form-control" />
                                        <span asp-validation-for="SortOrder" class="text-danger"></span>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label asp-for="Tags" class="control-label">
                                            <i class="fas fa-hashtag me-2"></i>Tags
                                        </label>
                                        <input asp-for="Tags" class="form-control" placeholder="tag1, tag2, tag3" />
                                        <span asp-validation-for="Tags" class="text-danger"></span>
                                        <small class="form-text text-muted">Separate tags with commas</small>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- SEO Fields -->
                            <div class="row mt-3">
                                <div class="col-12">
                                    <h6><i class="fas fa-search me-2"></i>SEO Settings</h6>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="MetaTitle" class="control-label">Meta Title</label>
                                        <input asp-for="MetaTitle" class="form-control" placeholder="SEO title" />
                                        <span asp-validation-for="MetaTitle" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="MetaDescription" class="control-label">Meta Description</label>
                                        <textarea asp-for="MetaDescription" class="form-control" rows="2" placeholder="SEO description"></textarea>
                                        <span asp-validation-for="MetaDescription" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-group d-flex gap-3 flex-column flex-sm-row mt-4">
                        <button type="submit" class="btn btn-custom-primary flex-fill">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-info flex-fill">
                            <i class="fas fa-eye me-2"></i>View Details
                        </a>
                        <a asp-action="Index" class="btn btn-custom-secondary flex-fill">
                            <i class="fas fa-arrow-left me-2"></i>Back to List
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}