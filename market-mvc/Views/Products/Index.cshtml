@model newApp.Models.PaginatedResult<newApp.Models.entity.Product>

@{
    ViewData["Title"] = "Products";
    ViewBag.PageTitle = "Product Management";
    ViewBag.Breadcrumbs = new List<(string Name, string Controller, string Action)>
    {
        ("Products", "Products", "Index")
    };
}

@await Html.PartialAsync("_PageHeader")

<div class="container">
    @await Html.PartialAsync("_SearchFilter")

    <div class="content-card">
        <div class="action-buttons">
            <a asp-action="Create" class="btn btn-custom-primary">
                <i class="fas fa-plus me-2"></i>Create New Product
            </a>
        </div>

        <div id="resultsContainer">
            @await Html.PartialAsync("_ProductList", Model.Items)
        </div>

        <div id="paginationContainer"></div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize search and filter functionality
            const searchManager = new SearchFilterManager({
                searchUrl: '@Url.Action("Index", "Products")',
                filterSelects: ['#PriceRange']
            });

            // Set initial data if we have results
            @if (Model.TotalItems > 0)
            {
                <text>
                searchManager.totalItems = @Model.TotalItems;
                searchManager.currentPage = @Model.CurrentPage;
                searchManager.pageSize = @Model.PageSize;
                searchManager.totalPages = @Model.TotalPages;
                searchManager.updateResultsInfo();
                searchManager.updatePagination();
                </text>
            }
        });
    </script>
}