@model newApp.Models.entity.Product

@{
    ViewData["Title"] = "Product Details";
    ViewBag.PageTitle = "Product Details";
    ViewBag.Breadcrumbs = new List<(string Name, string Controller, string Action)>
    {
        ("Products", "Products", "Index"),
        ("Details", "Products", "Details")
    };
}

@await Html.PartialAsync("_PageHeader")

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="details-card">
                <div class="row">
                    <div class="col-12 col-md-4 text-center mb-4 mb-md-0">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" alt="@Model.Name" class="product-image-large mb-3" />
                        }
                        else
                        {
                            <div class="product-image-placeholder-large mb-3">
                                <i class="fas fa-image"></i>
                            </div>
                        }
                        <h3 class="mb-0">@Model.Name</h3>
                    </div>
                    
                    <div class="col-12 col-md-8">
                        <div class="detail-row">
                            <div class="row">
                                <div class="col-sm-4">
                                    <div class="detail-label">
                                        <i class="fas fa-fingerprint me-2"></i>Product ID
                                    </div>
                                </div>
                                <div class="col-sm-8">
                                    <div class="detail-value">
                                        <code>@Html.DisplayFor(model => model.Id)</code>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="detail-row">
                            <div class="row">
                                <div class="col-sm-4">
                                    <div class="detail-label">
                                        <i class="fas fa-tag me-2"></i>Name
                                    </div>
                                </div>
                                <div class="col-sm-8">
                                    <div class="detail-value">@Html.DisplayFor(model => model.Name)</div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="detail-row">
                            <div class="row">
                                <div class="col-sm-4">
                                    <div class="detail-label">
                                        <i class="fas fa-dollar-sign me-2"></i>Price
                                    </div>
                                </div>
                                <div class="col-sm-8">
                                    <div class="detail-value">
                                        <span class="badge bg-success fs-4">$@Html.DisplayFor(model => model.Price)</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="detail-row">
                                <div class="row">
                                    <div class="col-sm-4">
                                        <div class="detail-label">
                                            <i class="fas fa-image me-2"></i>Image URL
                                        </div>
                                    </div>
                                    <div class="col-sm-8">
                                        <div class="detail-value">
                                            <a href="@Model.ImageUrl" target="_blank" class="text-break">@Model.ImageUrl</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                
                <div class="d-flex gap-3 justify-content-center mt-4 flex-column flex-sm-row">
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning flex-fill">
                        <i class="fas fa-edit me-2"></i>Edit Product
                    </a>
                    <a asp-action="Index" class="btn btn-custom-secondary flex-fill">
                        <i class="fas fa-arrow-left me-2"></i>Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>