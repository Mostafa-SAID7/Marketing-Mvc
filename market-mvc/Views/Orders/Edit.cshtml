@model newApp.Models.entity.Order

@{
    ViewData["Title"] = "Edit Order";
    ViewBag.PageTitle = "Edit Order";
    ViewBag.Breadcrumbs = new List<(string Name, string Controller, string Action)>
    {
        ("Orders", "Orders", "Index"),
        ("Edit", "Orders", "Edit")
    };
}

@await Html.PartialAsync("_PageHeader")

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="form-enhanced">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger-enhanced"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />
                    
                    <div class="form-group">
                        <label class="control-label">
                            <i class="fas fa-hashtag me-2"></i>Order ID
                        </label>
                        <input value="#@Model.Id.ToString().Substring(0, 8).ToUpper()" class="form-control" readonly />
                        <small class="form-text text-muted">Order ID cannot be changed</small>
                    </div>
                    
                    <div class="form-group">
                        <label asp-for="Total" class="control-label">
                            <i class="fas fa-dollar-sign me-2"></i>Order Total
                        </label>
                        <input asp-for="Total" class="form-control" placeholder="0.00" step="0.01" />
                        <span asp-validation-for="Total" class="text-danger"></span>
                    </div>
                    
                    <div class="form-group">
                        <label class="control-label">
                            <i class="fas fa-calendar me-2"></i>Created Date
                        </label>
                        <input value="@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")" class="form-control" readonly />
                        <small class="form-text text-muted">Creation date cannot be changed</small>
                    </div>
                    
                    <div class="form-group d-flex gap-3">
                        <button type="submit" class="btn btn-custom-primary">
                            <i class="fas fa-save me-2"></i>Save Changes
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-info">
                            <i class="fas fa-eye me-2"></i>View Details
                        </a>
                        <a asp-action="Index" class="btn btn-custom-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Back to List
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}