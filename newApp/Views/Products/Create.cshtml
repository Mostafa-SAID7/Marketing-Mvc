@model newApp.Models.entity.Product

@{
    ViewData["Title"] = "Create Product";
    ViewBag.PageTitle = "Create New Product";
    ViewBag.Breadcrumbs = new List<(string Name, string Controller, string Action)>
    {
        ("Products", "Products", "Index"),
        ("Create", "Products", "Create")
    };
}

@await Html.PartialAsync("_PageHeader")

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="form-enhanced">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger-enhanced"></div>
                    
                    <div class="form-group">
                        <label asp-for="Name" class="control-label">
                            <i class="fas fa-tag me-2"></i>Product Name
                        </label>
                        <input asp-for="Name" class="form-control" placeholder="Enter product name" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    
                    <div class="form-group">
                        <label asp-for="Price" class="control-label">
                            <i class="fas fa-dollar-sign me-2"></i>Price
                        </label>
                        <input asp-for="Price" class="form-control" placeholder="0.00" step="0.01" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                    
                    <div class="form-group d-flex gap-3">
                        <button type="submit" class="btn btn-custom-primary">
                            <i class="fas fa-save me-2"></i>Create Product
                        </button>
                        <a asp-action="Index" class="btn btn-custom-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Back to List
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}