@model newApp.Models.entity.Product

@{
    ViewData["Title"] = "Product Details";
    ViewBag.PageTitle = "Product Details";
    ViewBag.Breadcrumbs = new List<(string Name, string Controller, string Action)>
    {
        ("Products", "Products", "Index"),
        ("Details", "Products", "Details")
    };
}

@await Html.PartialAsync("_PageHeader")

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="details-card">
                <div class="text-center mb-4">
                    <i class="fas fa-box fa-3x text-primary mb-3"></i>
                    <h3>@Model.Name</h3>
                </div>
                
                <div class="detail-row">
                    <div class="row">
                        <div class="col-sm-3">
                            <div class="detail-label">
                                <i class="fas fa-fingerprint me-2"></i>Product ID
                            </div>
                        </div>
                        <div class="col-sm-9">
                            <div class="detail-value">@Html.DisplayFor(model => model.Id)</div>
                        </div>
                    </div>
                </div>
                
                <div class="detail-row">
                    <div class="row">
                        <div class="col-sm-3">
                            <div class="detail-label">
                                <i class="fas fa-tag me-2"></i>Name
                            </div>
                        </div>
                        <div class="col-sm-9">
                            <div class="detail-value">@Html.DisplayFor(model => model.Name)</div>
                        </div>
                    </div>
                </div>
                
                <div class="detail-row">
                    <div class="row">
                        <div class="col-sm-3">
                            <div class="detail-label">
                                <i class="fas fa-dollar-sign me-2"></i>Price
                            </div>
                        </div>
                        <div class="col-sm-9">
                            <div class="detail-value">
                                <span class="badge bg-success fs-5">$@Html.DisplayFor(model => model.Price)</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="d-flex gap-3 justify-content-center mt-4">
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">
                        <i class="fas fa-edit me-2"></i>Edit Product
                    </a>
                    <a asp-action="Index" class="btn btn-custom-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>