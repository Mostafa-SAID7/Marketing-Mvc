@model CreateOrderViewModel

@{
    ViewData["Title"] = "Create Order";
    ViewBag.PageTitle = "Create New Order";
    ViewBag.Breadcrumbs = new List<(string Name, string Controller, string Action)>
    {
        ("Orders", "Orders", "Index"),
        ("Create", "Orders", "Create")
    };
}

@await Html.PartialAsync("_PageHeader")

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            @if (Model?.OrderId != null && Model.OrderId != Guid.Empty)
            {
                <div class="alert alert-success-enhanced text-center mb-4">
                    <i class="fas fa-check-circle fa-2x mb-3"></i>
                    <h4>Order Created Successfully!</h4>
                    <p class="mb-0">Order ID: <code>#@Model.OrderId.ToString().Substring(0, 8).ToUpper()</code></p>
                    <div class="mt-3">
                        <a asp-action="Index" class="btn btn-custom-primary">
                            <i class="fas fa-list me-2"></i>View All Orders
                        </a>
                        <a asp-action="Details" asp-route-id="@Model.OrderId" class="btn btn-info">
                            <i class="fas fa-eye me-2"></i>View Order Details
                        </a>
                    </div>
                </div>
            }

            <div class="form-enhanced">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="form-group">
                        <label asp-for="Total" class="control-label">
                            <i class="fas fa-dollar-sign me-2"></i>Order Total
                        </label>
                        <input asp-for="Total" class="form-control" placeholder="0.00" step="0.01" />
                        <span asp-validation-for="Total" class="text-danger"></span>
                        <small class="form-text text-muted">Enter the total amount for this order</small>
                    </div>
                    
                    <div class="form-group d-flex gap-3">
                        <button type="submit" class="btn btn-custom-primary">
                            <i class="fas fa-save me-2"></i>Create Order
                        </button>
                        <a asp-action="Index" class="btn btn-custom-secondary">
                            <i class="fas fa-arrow-left me-2"></i>Back to List
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
