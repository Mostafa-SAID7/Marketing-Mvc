@model IEnumerable<newApp.Models.entity.Order>

@{
    ViewData["Title"] = "Orders";
    ViewBag.PageTitle = "Order Management";
    ViewBag.Breadcrumbs = new List<(string Name, string Controller, string Action)>
    {
        ("Orders", "Orders", "Index")
    };
}

@await Html.PartialAsync("_PageHeader")

<div class="container">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success-enhanced alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="content-card">
        <div class="action-buttons">
            <a asp-action="Create" class="btn btn-custom-primary">
                <i class="fas fa-plus me-2"></i>Create New Order
            </a>
        </div>

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-enhanced mb-0">
                    <thead>
                        <tr>
                            <th><i class="fas fa-hashtag me-2"></i>Order ID</th>
                            <th><i class="fas fa-dollar-sign me-2"></i>Total</th>
                            <th><i class="fas fa-calendar me-2"></i>Created Date</th>
                            <th><i class="fas fa-cogs me-2"></i>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <code>#@item.Id.ToString().Substring(0, 8).ToUpper()</code>
                                </td>
                                <td>
                                    <span class="badge bg-success fs-6">$@Html.DisplayFor(modelItem => item.Total)</span>
                                </td>
                                <td>
                                    <i class="fas fa-clock me-1"></i>@item.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button type="button" class="btn btn-danger btn-sm" title="Delete"
                                                onclick="showDeleteModal('Order', '@item.Id', 'Order #@item.Id.ToString().Substring(0, 8)', '@Url.Action("Delete", "Orders", new { id = item.Id })', 'Total: $@item.Total - Created: @item.CreatedAt.ToString("yyyy-MM-dd")')">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-shopping-cart fa-3x text-muted mb-3"></i>
                <h4 class="text-muted">No Orders Found</h4>
                <p class="text-muted">Start by creating your first order.</p>
                <a asp-action="Create" class="btn btn-custom-primary">
                    <i class="fas fa-plus me-2"></i>Create First Order
                </a>
            </div>
        }
    </div>
</div>