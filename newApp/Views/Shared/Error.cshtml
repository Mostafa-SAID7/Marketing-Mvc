@model newApp.Models.ViewModels.Error.ErrorVM
@{
    ViewData["Title"] = Model?.DisplayTitle ?? "Error";
    ViewBag.PageTitle = Model?.DisplayTitle ?? "Something went wrong";
    ViewBag.Breadcrumbs = new List<(string Name, string Controller, string Action)>
    {
        ("Error", "Error", "Error")
    };
}

@await Html.PartialAsync("_PageHeader")

<div class="container">
    <div class="content-card">
        <div class="error-page">
            <div class="error-code @Model.StatusCodeClass">
                <i class="@Model.IconClass me-2"></i>@(Model?.StatusCode ?? 500)
            </div>
            <div class="error-message">@(Model?.DisplayTitle ?? "Oops! Something went wrong.")</div>
            <p class="text-muted mb-4">@(Model?.GetUserFriendlyDescription() ?? "An error occurred while processing your request. Please try again later.")</p>
            
            @if (Model?.ShowRequestId == true)
            {
                <div class="alert alert-info-enhanced mb-4">
                    <div class="row">
                        <div class="col-md-6">
                            <strong>Request ID:</strong> <code>@Model.RequestId</code>
                        </div>
                        <div class="col-md-6">
                            <strong>Time:</strong> @Model.FormattedErrorTime
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.RequestPath))
                    {
                        <div class="row mt-2">
                            <div class="col-md-6">
                                <strong>Path:</strong> <code>@Model.RequestPath</code>
                            </div>
                            <div class="col-md-6">
                                <strong>Method:</strong> <code>@Model.HttpMethod</code>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (Model?.ShowDetails == true && !string.IsNullOrEmpty(Model.ExceptionMessage))
            {
                <div class="alert alert-danger-enhanced mb-4">
                    <h6><i class="fas fa-exclamation-triangle me-2"></i>Exception Details (Development Mode)</h6>
                    <p><strong>Message:</strong> @Model.ExceptionMessage</p>
                    @if (!string.IsNullOrEmpty(Model.StackTrace))
                    {
                        <details class="mt-2">
                            <summary>Stack Trace</summary>
                            <pre class="mt-2 small">@Model.StackTrace</pre>
                        </details>
                    }
                </div>
            }
            
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a asp-controller="Home" asp-action="Index" class="btn btn-custom-primary">
                    <i class="fas fa-home me-2"></i>Go Home
                </a>
                <button onclick="history.back()" class="btn btn-custom-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Go Back
                </button>
                <button onclick="location.reload()" class="btn btn-outline-primary">
                    <i class="fas fa-redo me-2"></i>Try Again
                </button>
            </div>
            
            <div class="mt-4">
                <h5>Quick Links:</h5>
                <div class="d-flex justify-content-center gap-3 mt-3 flex-wrap">
                    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary btn-sm">
                        <i class="fas fa-box me-1"></i>Products
                    </a>
                    <a asp-controller="Orders" asp-action="Index" class="btn btn-outline-success btn-sm">
                        <i class="fas fa-shopping-cart me-1"></i>Orders
                    </a>
                    <a asp-controller="Items" asp-action="Index" class="btn btn-outline-info btn-sm">
                        <i class="fas fa-list me-1"></i>Items
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
