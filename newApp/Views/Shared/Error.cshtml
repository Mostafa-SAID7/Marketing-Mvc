@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
    ViewBag.PageTitle = "Something went wrong";
    ViewBag.Breadcrumbs = new List<(string Name, string Controller, string Action)>
    {
        ("Error", "Error", "Error")
    };
}

@await Html.PartialAsync("_PageHeader")

<div class="container">
    <div class="content-card">
        <div class="error-page">
            <div class="error-code">500</div>
            <div class="error-message">Oops! Something went wrong.</div>
            <p class="text-muted mb-4">An error occurred while processing your request. Please try again later.</p>
            
            @if (Model.ShowRequestId)
            {
                <div class="alert alert-info-enhanced mb-4">
                    <strong>Request ID:</strong> <code>@Model.RequestId</code>
                </div>
            }
            
            <div class="d-flex justify-content-center gap-3">
                <a asp-controller="Home" asp-action="Index" class="btn btn-custom-primary">
                    <i class="fas fa-home me-2"></i>Go Home
                </a>
                <button onclick="history.back()" class="btn btn-custom-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Go Back
                </button>
            </div>
            
            <div class="mt-4">
                <h5>Quick Links:</h5>
                <div class="d-flex justify-content-center gap-3 mt-3">
                    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary btn-sm">Products</a>
                    <a asp-controller="Orders" asp-action="Index" class="btn btn-outline-primary btn-sm">Orders</a>
                    <a asp-controller="Items" asp-action="Index" class="btn btn-outline-primary btn-sm">Items</a>
                </div>
            </div>
        </div>
    </div>
</div>
