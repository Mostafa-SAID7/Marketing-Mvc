@model dynamic

@{
    var title = ViewBag.PageTitle ?? ViewData["Title"] ?? "Page";
    var breadcrumbs = ViewBag.Breadcrumbs as List<(string Name, string Controller, string Action)> ?? new List<(string, string, string)>();
}

<div class="page-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1>@title</h1>
            </div>
            <div class="col-md-6">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb justify-content-md-end">
                        <li class="breadcrumb-item">
                            <a asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1"></i>Home
                            </a>
                        </li>
                        @foreach (var breadcrumb in breadcrumbs)
                        {
                            @if (breadcrumb == breadcrumbs.Last())
                            {
                                <li class="breadcrumb-item active" aria-current="page">@breadcrumb.Name</li>
                            }
                            else
                            {
                                <li class="breadcrumb-item">
                                    <a asp-controller="@breadcrumb.Controller" asp-action="@breadcrumb.Action">@breadcrumb.Name</a>
                                </li>
                            }
                        }
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>