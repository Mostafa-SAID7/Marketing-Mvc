@model dynamic

@{
    var title = ViewBag.PageTitle ?? ViewData["Title"] ?? "Page";
    var breadcrumbs = ViewBag.Breadcrumbs as List<(string Name, string Controller, string Action)> ?? new List<(string, string, string)>();
}

<div class="page-header">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-12 col-md-6">
                <h1>@title</h1>
            </div>
            <div class="col-12 col-md-6">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb justify-content-md-end justify-content-center">
                        <li class="breadcrumb-item">
                            <a asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1"></i>
                                <span class="d-none d-sm-inline">Home</span>
                            </a>
                        </li>
                        @foreach (var breadcrumb in breadcrumbs)
                        {
                            @if (breadcrumb == breadcrumbs.Last())
                            {
                                <li class="breadcrumb-item active" aria-current="page">
                                    <span class="d-none d-sm-inline">@breadcrumb.Name</span>
                                    <span class="d-sm-none">@breadcrumb.Name.Substring(0, Math.Min(breadcrumb.Name.Length, 10))</span>
                                </li>
                            }
                            else
                            {
                                <li class="breadcrumb-item">
                                    <a asp-controller="@breadcrumb.Controller" asp-action="@breadcrumb.Action">
                                        <span class="d-none d-sm-inline">@breadcrumb.Name</span>
                                        <span class="d-sm-none">@breadcrumb.Name.Substring(0, Math.Min(breadcrumb.Name.Length, 10))</span>
                                    </a>
                                </li>
                            }
                        }
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>