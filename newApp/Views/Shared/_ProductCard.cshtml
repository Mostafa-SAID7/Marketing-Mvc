@model newApp.Models.ViewModels.Product.ProductCardVM

<div class="col">
    <div class="card product-card h-100 shadow-sm">
        @if (Model.IsOnSale)
        {
            <div class="position-absolute top-0 start-0 m-2">
                <span class="badge bg-danger">
                    @if (Model.SavingsPercentage.HasValue)
                    {
                        <text>-@Model.SavingsPercentage.Value%</text>
                    }
                    else
                    {
                        <text>Sale</text>
                    }
                </span>
            </div>
        }

        @if (Model.IsFeatured)
        {
            <div class="position-absolute top-0 end-0 m-2">
                <span class="badge bg-warning text-dark">
                    <i class="fas fa-star"></i> Featured
                </span>
            </div>
        }

        @if (Model.IsOutOfStock)
        {
            <div class="position-absolute top-50 start-50 translate-middle">
                <span class="badge bg-danger fs-6 px-3 py-2">Out of Stock</span>
            </div>
        }

        <div class="card-img-container position-relative">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" 
                     alt="@(Model.ImageAlt ?? Model.Name)" 
                     class="card-img-top product-card-image @(Model.IsOutOfStock ? "out-of-stock" : "")" />
            }
            else
            {
                <div class="product-card-image-placeholder @(Model.IsOutOfStock ? "out-of-stock" : "")">
                    <i class="fas fa-image fa-3x text-muted"></i>
                </div>
            }
        </div>

        <div class="card-body d-flex flex-column">
            @if (!string.IsNullOrEmpty(Model.CategoryName))
            {
                <small class="text-muted mb-1">@Model.CategoryName</small>
            }
            
            <h5 class="card-title">@Model.Name</h5>
            
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p class="card-text text-muted small">
                    @(Model.Description.Length > 80 ? Model.Description.Substring(0, 80) + "..." : Model.Description)
                </p>
            }

            <div class="mt-auto">
                <div class="price-section mb-3">
                    <div class="d-flex align-items-center gap-2">
                        <span class="h5 mb-0 text-primary fw-bold">$@Model.Price.ToString("F2")</span>
                        @if (Model.CompareAtPrice.HasValue && Model.CompareAtPrice > Model.Price)
                        {
                            <span class="text-muted text-decoration-line-through">$@Model.CompareAtPrice.Value.ToString("F2")</span>
                            @if (Model.SavingsAmount.HasValue)
                            {
                                <small class="text-success fw-bold">Save $@Model.SavingsAmount.Value.ToString("F2")</small>
                            }
                        }
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <a asp-controller="Products" asp-action="Details" asp-route-id="@Model.Id" 
                       class="btn btn-outline-primary btn-sm flex-fill">
                        <i class="fas fa-eye me-1"></i>View
                    </a>
                    @if (!Model.IsOutOfStock)
                    {
                        <button class="btn btn-primary btn-sm flex-fill" onclick="addToCart('@Model.Id')">
                            <i class="fas fa-shopping-cart me-1"></i>Add to Cart
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-secondary btn-sm flex-fill" disabled>
                            <i class="fas fa-times me-1"></i>Out of Stock
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>